		/// <summary>
		/// The selected ascent type.
		/// 
		/// 0 = <see cref="AscentClassic" /> (Classic Ascent Profile)
		/// 
		/// 1 = <see cref="AscentPVG" /> (Primer Vector Guidance (RSS/RO))
		/// </summary>
		[KRPCProperty]
		public int AscentType {	
			get => (int)AscentSettings.ascentType.GetValue(this.guiInstance);
			set {
				if(value < 0 || value > 1)
					return;

				AscentSettings.ascentType.SetValue(this.guiInstance, value);
			}
		}

